# ─── Bhavishya IAS — environment contract ───
# Copy to .env.local (dev) / configure in the deployment platform.
# Parsed and validated at boot by src/lib/validation/env.ts (fails fast).

# Core
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bhavishya?schema=public

# Cache / sessions / rate-limit (Redis)
REDIS_URL=redis://localhost:6379

# Auth.js (Phase 8)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Storage (AWS S3 or S3-compatible)
S3_REGION=ap-south-1
S3_BUCKET=bhavishya-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Mail (email OTP + transactional)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@bhavishyaias.app
